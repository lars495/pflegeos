# Copy to infra/.env and fill in real values. NEVER commit infra/.env.

ENV=production

# Database
POSTGRES_USER=pflegeos
POSTGRES_PASSWORD=change_me_to_strong_password

# Redis
REDIS_PASSWORD=change_me_to_strong_password

# OpenRouter (Build-Agent + Produktiv-LLM)
OPENROUTER_API_KEY=sk-or-v1-...

# GitHub PAT für Community-Feedback (issues: write auf lars495/pflegeos)
# Erstellen: github.com/settings/tokens → Fine-grained → Repository: lars495/pflegeos → Issues: Read+Write
# Denselben Token auch als GITHUB_FEEDBACK_TOKEN in Vercel-Projektumgebung eintragen!
GITHUB_FEEDBACK_TOKEN=github_pat_...

# Soziale Updates (optional — leer lassen, dann skippt der Posting-Schritt)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=

# Public domains
PUBLIC_DOMAIN=pflegeos.de
CARE_DOMAIN=care.pflegeos.de
API_DOMAIN=api.pflegeos.de

# Legal-Audit (eigener Topf)
LEGAL_AUDIT_MONTHLY_BUDGET_USD=6
